    {
      "parameters": {
        "jsCode": "const overlay = $input.first().json.ParsedResults[0].TextOverlay.Lines\n\nconst top = overlay.find(line => \n  line.LineText.toLowerCase().includes(\"date\".toLowerCase())\n)\nconst bottom = overlay.find(line => \n  line.LineText.toLowerCase().includes(\"selector\".toLowerCase())\n)\n\nif (!top || !bottom) {\n  throw new Error(\"Could not find 'Date' or 'Distance'.\");\n}\n\nconst x = top.Words[0].Left - 25\nconst y = top.Words[0].Top - 25\nconst w = bottom.Words[0].Left + bottom.Words[0].Width - x\nconst h = bottom.Words[0].Top - y\n\nreturn {\n  json: {\n    crop: `c_crop,x_${x},y_${y},w_${w},h_${h}`\n  }\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        176,
        144
      ],
      "id": "d2c7437a-dc71-4d64-abfa-7a875c0cbe75",
