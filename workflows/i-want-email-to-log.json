        "jsCode": "// https://res.cloudinary.com/deegzgpvw/image/upload/{ $('Get boundings').item.json.crop }/v{{ $('Upload to cloudinary.com1').item.json.version }}/{{ $('Upload to cloudinary.com1').item.json.public_id }}.{{ $('Upload to cloudinary.com1').item.json.format }}\n\nconst cropped_url = [\n  `https://res.cloudinary.com/deegzgpvw/image/upload`,\n  `${ $input.first().json.crop }`,\n  `v${$('Upload to cloudinary.com1').first().json.version}`,\n  `${$('Upload to cloudinary.com1').first().json.public_id}.${$('Upload to cloudinary.com1').first().json.format}`\n].join(\"/\")\n\nreturn {\n  json: {\n    url: $('Upload to cloudinary.com1').first().json.secure_url,\n    cropped_url\n  }\n};"
      },
