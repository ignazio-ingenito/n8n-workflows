    {
      "parameters": {
        "jsCode": "const models = {\n  llama3: \"meta-llama/llama-3.3-70b-instruct:free\",\n  llama4Maverick: \"meta-llama/llama-4-maverick:free\",\n  llama4Scout: \"meta-llama/llama-4-scout:free\"\n}\n\nreturn [{\n  body: {\n    model: models.llama3,\n    messages: [\n      {\n        role: \"user\",\n        content: [\n          { \n            type: \"text\", \n            text: [\n              \"```json\\n\",\n              JSON.stringify($input.first().json.ParsedResults),\n              \"```\",\n              \"\",\n              \"- Extract date, start, end, from, to, duration, distance from the above ocr scan json response.\",\n              \"- Convert dates/times to ISO 8601 UTC, duration to minutes.\",\n              \"- Return the json only with the requested field, no text, no explanation.\"\n            ].join(\"\\n\")\n          }\n        ]\n      }\n    ]\n  }\n,\n}];\n"
