      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "function rewriteFeatured(markdown, featuredValue) {\n  const match = markdown.match(/^---\\n([\\s\\S]*?)\\n---\\n?/);\n\n  if (!match) {\n    throw new Error('Missing YAML frontmatter');\n  }\n\n  const frontmatterLines = match[1].split('\\n');\n  let foundFeatured = false;\n\n  const rewrittenLines = frontmatterLines.map((line) => {\n    if (/^featured:\\s*/.test(line)) {\n      foundFeatured = true;\n      return 'featured: ' + featuredValue;\n    }\n\n    return line;\n  });\n\n  if (!foundFeatured) {\n    rewrittenLines.push('featured: ' + featuredValue);\n  }\n\n  return '---\\n' + rewrittenLines.join('\\n') + '\\n---\\n' + markdown.slice(match[0].length);\n}\n\nconst approval = $('Load approval row for choice').first().json;\nconst file = $('Fetch file metadata').first().json;\n\nif (!approval) {\n  throw new Error('Missing approval row');\n}\n\nif (!file) {\n  throw new Error('Missing file metadata');\n}\n\nconst decodedContent = Buffer.from(file.content ?? '', 'base64').toString('utf8');\n\nif (!decodedContent) {\n  throw new Error('Missing file content from GitHub');\n}\n\nconst updatedContent = rewriteFeatured(decodedContent, 1);\n\nreturn [\n  {\n    json: {\n      ...approval,\n      owner: approval.owner ?? \"ignazio-ingenito\",\n      repo: approval.repo ?? \"baialupo.com\",\n      branch: approval.branch ?? \"main\",\n      path: file.path ?? approval.path,\n      sha: file.sha,\n      title: approval.selectedTitle,\n      slug: approval.selectedSlug,\n      publicUrl: approval.publicUrl,\n      runId: approval.runId,\n      chatId: approval.chatId,\n      selected: true,\n      selectedChoice: approval.selectedChoice,\n      updatedContent,\n      commitMessage: 'feat(content): toggle featured for ' + approval.selectedSlug,\n    },\n  },\n];"
      },
