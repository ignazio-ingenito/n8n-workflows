      "name": "Receive shortlist"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const inbound = $input.first().json.body ?? $input.first().json;\nconst candidates = inbound.candidates;\n\nif (!Array.isArray(candidates) || candidates.length === 0 || candidates.length > 5) {\n  throw new Error('Expected 1 to 5 candidates');\n}\n\nconst chatId = inbound.chat_id;\nif (!chatId) {\n  throw new Error('Missing chat_id in shortlist payload');\n}\n\nconst runId = inbound.run_id ?? ('baialupo-' + new Date().toISOString().slice(0, 10));\n\nconst shortDescription = (candidate) => {\n  if (candidate.description) {\n    return candidate.description;\n  }\n\n  const body = candidate.content\n    .replace(/^---[\\s\\S]*?---\\n?/, '')\n    .replace(/\\s+/g, ' ')\n    .trim();\n\n  return body.slice(0, 140);\n};\n\nconst normalized = candidates.map((candidate, index) => {\n  if (!candidate.path || !candidate.title || !candidate.slug || !candidate.content) {\n    throw new Error('Candidate ' + (index + 1) + ' is missing path, title, slug or content');\n  }\n\n  return {\n    index: index + 1,\n    path: candidate.path,\n    title: candidate.title,\n    slug: candidate.slug,\n    description: shortDescription(candidate),\n    expires: candidate.expires ?? null,\n  };\n});\n\nconst approvalUrl = 'https://hooks.skunklabs.uk/webhook/baia/telegram/approve?runId=' + encodeURIComponent(runId);\nconst lines = normalized.map((candidate) => {\n  const expiry = candidate.expires ? ' (scade ' + candidate.expires + ')' : '';\n  return candidate.index + '. ' + candidate.title + expiry;\n});\n\nconst message = [\n  'Baialupo shortlist ' + runId,\n  '',\n  ...lines,\n  '',\n  '<a href=\"' + approvalUrl + '\">Apri la pagina di approvazione</a>',\n  'Clicca il titolo dell articolo da pubblicare.',\n].join('\\n');\n\nreturn [\n  {\n    json: {\n      runId,\n      chatId,\n      count: normalized.length,\n      approvalUrl,\n      candidates,\n      normalizedCandidates: normalized,\n      message,\n    },\n  },\n];"
      },
