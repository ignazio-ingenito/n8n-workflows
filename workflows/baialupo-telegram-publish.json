      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "function escapeHtml(value) {\n  return String(value)\n    .replaceAll('&', '&amp;')\n    .replaceAll('<', '&lt;')\n    .replaceAll('>', '&gt;')\n    .replaceAll('\\\"', '&quot;')\n    .replaceAll(\"'\", '&#39;');\n}\n\nconst row = $input.first().json;\nif (!row) {\n  throw new Error('No Baialupo shortlist is waiting for approval');\n}\n\nconst candidates = JSON.parse(row.candidatesJson ?? '[]');\nif (!Array.isArray(candidates) || candidates.length === 0) {\n  throw new Error('Invalid Baialupo approval row');\n}\n\nconst rows = candidates.map((candidate) => {\n  const href = 'https://hooks.skunklabs.uk/webhook/baia/telegram/publish?choice=' + candidate.index + '&runId=' + encodeURIComponent(row.runId);\n  const expiry = candidate.expires ? ' <span class=\"expiry\">(scade ' + escapeHtml(candidate.expires) + ')</span>' : '';\n  return '<li class=\"candidate\">' +\n    '<a class=\"choice\" href=\"' + href + '\">' + escapeHtml(candidate.title) + '</a>' +\n    '<div class=\"description\">' + escapeHtml(candidate.description) + '</div>' +\n    '<div class=\"meta\">' + candidate.index + expiry + '</div>' +\n    '</li>';\n}).join('\\n');\n\nconst html = [\n  '<!doctype html>',\n  '<html lang=\"it\">',\n  '  <head>',\n  '    <meta charset=\"utf-8\">',\n  '    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">',\n  '    <title>Baialupo approval</title>',\n  '    <style>',\n  '      body { font-family: system-ui, sans-serif; margin: 24px; line-height: 1.4; }',\n  '      h1 { font-size: 1.25rem; margin: 0 0 1rem; }',\n  '      ol { padding-left: 1.25rem; }',\n  '      li { margin: 0 0 1rem; }',\n  '      .choice { font-weight: 700; text-decoration: none; }',\n  '      .description, .meta { color: #555; font-size: 0.95rem; }',\n  '      .meta { margin-top: 0.25rem; }',\n  '      .expiry { color: #7a4a00; }',\n  '    </style>',\n  '  </head>',\n  '  <body>',\n  '    <h1>Baialupo shortlist ' + escapeHtml(row.runId) + '</h1>',\n  '    <ol>',\n  '      ' + rows,\n  '    </ol>',\n  '  </body>',\n  '</html>',\n].join('\\n');\n\nreturn [{ json: { html, runId: row.runId } }];"
      }
    },
