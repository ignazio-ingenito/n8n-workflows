    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const owner = 'ignazio-ingenito';\nconst repo = 'baialupo.com';\nconst branch = 'main';\n\nreturn $input.all().flatMap((item) => {\n  const entries = Array.isArray(item.json)\n    ? item.json\n    : Array.isArray(item.json.data)\n      ? item.json.data\n      : [];\n\n  return entries\n    .filter((entry) => entry.type === 'file' && entry.path.endsWith('.md'))\n    .map((entry) => ({\n      json: {\n        owner,\n        repo,\n        branch,\n        path: entry.path,\n      },\n    }));\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -192,
        -160
      ],
      "id": "31e8d7c3-7d58-4f44-9b66-6a8f0ef20bd5",
      "name": "Expand files"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.github.com/repos/{{$json.owner}}/{{$json.repo}}/contents/{{$json.path}}?ref={{$json.branch}}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubApi",
        "options": {
          "sendCredentialsOnCrossOriginRedirect": true
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        64,
        -160
      ],
      "id": "1fc0e0b0-27f0-41a6-a4c7-94f6e5e3dbbb",
      "name": "Fetch file content",
      "credentials": {
        "githubApi": {
          "id": "eASX8oZcknKPY1lX",
          "name": "GitHub account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "function rewriteFeatured(markdown, featuredValue) {\n  const match = markdown.match(/^---\\n([\\s\\S]*?)\\n---\\n?/);\n\n  if (!match) {\n    throw new Error('Missing YAML frontmatter');\n  }\n\n  const frontmatterLines = match[1].split('\\n');\n  let foundFeatured = false;\n\n  const rewrittenLines = frontmatterLines.map((line) => {\n    if (/^featured:\\s*/.test(line)) {\n      foundFeatured = true;\n      return `featured: ${featuredValue}`;\n    }\n\n    return line;\n  });\n\n  if (!foundFeatured) {\n    rewrittenLines.push(`featured: ${featuredValue}`);\n  }\n\n  return `---\\n${rewrittenLines.join('\\n')}\\n---\\n${markdown.slice(match[0].length)}`;\n}\n\nconst today = new Date().toISOString().slice(0, 10);\n\nreturn $input.all().flatMap((item) => {\n  const content = String(item.json.content ?? '');\n  const markdown = Buffer.from(content, 'base64').toString('utf8');\n  const match = markdown.match(/^---\\n([\\s\\S]*?)\\n---\\n?/);\n\n  if (!match) {\n    return [];\n  }\n\n  const lines = match[1].split('\\n');\n  const featuredLine = lines.find((line) => /^featured:\\s*/.test(line));\n  const expiresLine = lines.find((line) => /^expires:\\s*/.test(line));\n\n  const featured = featuredLine ? Number(featuredLine.split(':')[1].trim()) : 0;\n  const expires = expiresLine ? expiresLine.split(':').slice(1).join(':').trim().slice(0, 10) : null;\n\n  if (featured !== 1 || !expires || expires > today) {\n    return [];\n  }\n\n  const updatedMarkdown = rewriteFeatured(markdown, 0);\n\n  return [\n    {\n      json: {\n        owner: 'ignazio-ingenito',\n        repo: 'baialupo.com',\n        branch: 'main',\n        path: item.json.path,\n        sha: item.json.sha,\n        contentBase64: Buffer.from(updatedMarkdown).toString('base64'),\n        commitMessage: `chore(content): demote expired featured ${item.json.path}`,\n      },\n    },\n  ];\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        320,
        -160
      ],
      "id": "d9b2f7fd-7cf5-46cf-b10d-1cf01ce8d10f",
