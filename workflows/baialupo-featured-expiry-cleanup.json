    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const owner = 'ignazio-ingenito';\nconst repo = 'baialupo.com';\nconst branch = 'main';\nconst categories = ['news', 'guide', 'sicurezza', 'baialupo'];\n\nreturn categories.map((category) => ({\n  json: {\n    owner,\n    repo,\n    branch,\n    categoryPath: `src/content/posts/${category}`,\n  },\n}));"
      },
